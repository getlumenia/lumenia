{
  "name": "lumenia",
  "version": "0.0.0",
  "private": true,
  "description": "Lumenia — send/request USDC by link; the recipient claims it walletless, seedless, gasless (Stellar)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "web:dev": "pnpm --filter @lumenia/web dev",
    "sponsor:dev": "pnpm --filter @lumenia/sponsor dev",
    "spike1": "pnpm --filter @lumenia/sponsor spike1",
    "spike1b": "pnpm --filter @lumenia/sponsor spike1b",
    "spike1c": "pnpm --filter @lumenia/sponsor spike1c",
    "spike4": "pnpm --filter @lumenia/sponsor spike4",
    "test:antidrain": "pnpm --filter @lumenia/sponsor test:antidrain"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.19",
      "axios": ">=1.18.0",
      "brace-expansion@>=3.0.0 <5.0.7": ">=5.0.7",
      "fast-uri": "^3.1.4",
      "sharp": "^0.35.0"
    }
  }
}
